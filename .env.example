# =============================================================
# FlowSpace - Environment Variables
# =============================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# --- App ---
NODE_ENV=production
PORT=3070
# Local dev: http://localhost:5173 — Production (Portainer): http://192.168.1.4:3070
APP_URL=http://192.168.1.4:3070

# --- Database (PostgreSQL) ---
DB_HOST=192.168.1.4
DB_PORT=5432
DB_NAME=productivity-hub
DB_USER=admin
DB_PASSWORD=

# --- Auth (Better Auth) ---
# Generate on server: openssl rand -base64 32
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://192.168.1.4:3070
# Legacy alias still supported by server
SESSION_SECRET=

# Self-hosted: allow registration (set false in production SaaS until ready)
ENABLE_SIGNUP=true

# --- AI / Gemini ---
GEMINI_API_KEY=
